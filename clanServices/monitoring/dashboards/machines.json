{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "panels": [],
      "repeat": "machine",
      "title": "${machine}",
      "type": "row"
    },
    {
      "datasource": "VictoriaMetrics",
      "description": "memory used as percentage of total",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "#EAB839", "value": 75 },
              { "color": "red", "value": 90 }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 1 },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto",
        "wideLayout": true
      },
      "pluginVersion": "12.4.0",
      "targets": [
        {
          "editorMode": "code",
          "expr": "max(mem_used_percent{machine=~\"$machine\"})",
          "legendFormat": "",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "memory used",
      "type": "stat"
    },
    {
      "datasource": "VictoriaMetrics",
      "description": "memory used / total",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "text", "value": null }]
          },
          "unit": "bytes"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "used" },
            "properties": [
              {
                "id": "color",
                "value": { "mode": "fixed", "fixedColor": "orange" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "total" },
            "properties": [
              {
                "id": "color",
                "value": { "mode": "fixed", "fixedColor": "blue" }
              }
            ]
          }
        ]
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name",
        "wideLayout": false
      },
      "pluginVersion": "12.4.0",
      "targets": [
        {
          "editorMode": "code",
          "expr": "max(mem_used{machine=~\"$machine\"})",
          "legendFormat": "used",
          "range": true,
          "refId": "A"
        },
        {
          "editorMode": "code",
          "expr": "max(mem_total{machine=~\"$machine\"})",
          "legendFormat": "total",
          "range": true,
          "refId": "B"
        }
      ],
      "title": "",
      "type": "stat"
    },
    {
      "datasource": "VictoriaMetrics",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "#EAB839",
                "value": 75
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 5 },
      "id": 5,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto",
        "wideLayout": true
      },
      "pluginVersion": "12.4.0",
      "description": "cpu used as percentage (100 - idle)",
      "targets": [
        {
          "editorMode": "code",
          "expr": "max(100 - cpu_usage_idle{machine=~\"$machine\",cpu=\"cpu-total\"})",
          "legendFormat": "",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "cpu used",
      "type": "stat"
    },
    {
      "datasource": "VictoriaMetrics",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "state" },
            "properties": [
              { "id": "custom.cellOptions", "value": { "type": "color-text" } },
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "active": {
                        "text": "active",
                        "color": "semi-dark-green",
                        "index": 0
                      },
                      "reloading": {
                        "text": "reloading",
                        "color": "semi-dark-blue",
                        "index": 1
                      },
                      "inactive": {
                        "text": "inactive",
                        "color": "#535353",
                        "index": 2
                      },
                      "failed": {
                        "text": "failed",
                        "color": "semi-dark-red",
                        "index": 3
                      },
                      "activating": {
                        "text": "activating",
                        "color": "semi-dark-yellow",
                        "index": 4
                      },
                      "deactivating": {
                        "text": "deactivating",
                        "color": "semi-dark-orange",
                        "index": 5
                      }
                    }
                  }
                ]
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "priority" },
            "properties": [{ "id": "custom.hidden", "value": true }]
          }
        ]
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 1
      },
      "id": 6,
      "options": {
        "cellHeight": "sm",
        "enablePagination": false,
        "footer": {
          "countRows": false,
          "fields": "",
          "reducer": ["sum"],
          "show": false
        },
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "priority" }]
      },
      "pluginVersion": "12.4.0",
      "targets": [
        {
          "datasource": "VictoriaMetrics",
          "editorMode": "code",
          "expr": "label_replace(6*(systemd_units_active_code{machine=~\"$machine\"} == bool 3) + 5*(systemd_units_active_code{machine=~\"$machine\"} == bool 4) + 4*(systemd_units_active_code{machine=~\"$machine\"} == bool 5) + 3*(systemd_units_active_code{machine=~\"$machine\"} == bool 1) + 2*(systemd_units_active_code{machine=~\"$machine\"} == bool 0) + 1*(systemd_units_active_code{machine=~\"$machine\"} == bool 2), \"service\", \"$1\", \"name\", \"(.*)\\\\.service\")",
          "format": "table",
          "instant": true,
          "range": false,
          "refId": "A"
        }
      ],
      "title": "service health",
      "transformations": [
        {
          "id": "filterFieldsByName",
          "options": {
            "include": {
              "names": ["service", "active", "sub", "Value"]
            },
            "byVariable": false
          }
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "Value": "priority",
              "active": "state",
              "service": "service",
              "sub": "substate"
            }
          }
        }
      ],
      "type": "table",
      "description": "current state of monitored NixOS services, sorted with non-active states first"
    },
    {
      "datasource": {
        "type": "victoriametrics-logs-datasource",
        "uid": "PD775F2863313E6C7"
      },
      "description": "recent error-level journal entries for the selected machine from VictoriaLogs",
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 9
      },
      "id": 7,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "pluginVersion": "12.4.0",
      "targets": [
        {
          "datasource": {
            "type": "victoriametrics-logs-datasource",
            "uid": "PD775F2863313E6C7"
          },
          "editorMode": "code",
          "expr": "{_HOSTNAME=~\"$machine\"} AND level:error AND NOT SYSLOG_IDENTIFIER:dbus-broker-launch",
          "maxLines": 100,
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "error logs",
      "type": "logs"
    }
  ],
  "preload": false,
  "refresh": "30s",
  "schemaVersion": 42,
  "tags": ["machines", "telegraf", "victorialogs"],
  "templating": {
    "list": [
      {
        "current": {
          "text": "All",
          "value": ["$__all"]
        },
        "datasource": "VictoriaMetrics",
        "definition": "label_values(mem_available, machine)",
        "includeAll": true,
        "multi": true,
        "name": "machine",
        "options": [],
        "query": {
          "query": "label_values(mem_available, machine)",
          "refId": "A"
        },
        "refresh": 1,
        "regex": "",
        "sort": 1,
        "type": "query",
        "hide": 2
      }
    ]
  },
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "title": "Machines",
  "uid": "machines",
  "version": 6
}
