{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":automergeRequireAllStatusChecks",
    "docker:pinDigests",
    "helpers:pinGitHubActionDigests",
    ":configMigration",
    "abandonments:recommended",
    "security:minimumReleaseAgeNpm",
    "security:openssf-scorecard",
    ":rebaseStalePrs",
    ":prImmediately"
  ],
  "dependencyDashboard": true,
  "automerge": true,
  "platformAutomerge": true,
  "lockFileMaintenance": {
    "enabled": false
  },
  "packageRules": [
    {
      "matchFileNames": ["templates/**"],
      "groupName": "template dependencies"
    },
    {
      "matchManagers": ["gomod"],
      "matchFileNames": ["packages/live-ocr/live-ocr/go.mod"],
      "postUpdateOptions": ["gomodTidy"],
      "postUpgradeTasks": {
        "commands": ["bash packages/live-ocr/update-vendor-hash.sh"],
        "fileFilters": [
          "packages/live-ocr/default.nix",
          "packages/live-ocr/live-ocr/go.mod",
          "packages/live-ocr/live-ocr/go.sum"
        ],
        "executionMode": "branch"
      }
    }
  ],
  "nix": {
    "enabled": true
  }
}
